# Environment Configuration
# These are DEPLOYMENT-TIME values, separate from runtime CONFIG per LLD §9

# Application
NODE_ENV=development
PORT=3000

# LLM Provider (Phase 6 - AIMAP)
LLM_API_KEY=your_openai_api_key_here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Legacy key name (kept for compatibility)
LLM_PROVIDER_API_KEY=your_api_key_here
LLM_PROVIDER_ENDPOINT=https://api.openai.com/v1

# Database / Persistence (Phase 2+)
DATABASE_URL=postgresql://user:password@localhost:5432/crm_ingestion

# Storage (Phase 14 - Export artifacts)
STORAGE_PATH=./data/uploads
OUTPUT_PATH=./data/outputs

# Security
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=info
